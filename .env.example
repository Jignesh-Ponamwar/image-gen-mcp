# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# OpenRouter API Key
# Generate at: https://openrouter.ai/
# Required for image generation via Google Gemini and OpenAI models
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# MCP Authentication Token
# Secure token for authorizing HTTP requests to MCP endpoints
# Recommended: Generate with: openssl rand -base64 32
# Minimum: 32 characters, alphanumeric + symbols recommended
MCP_AUTH_TOKEN=your-secure-mcp-auth-token-min-32-chars-here

# ============================================================================
# OPTIONAL CONFIGURATION (Defaults Applied if Not Set)
# ============================================================================

# Environment Mode
# Options: development | production | staging
# Default: development
NODE_ENV=development

# Logging Level
# Options: debug | info | warn | error
# Default: info
LOG_LEVEL=info

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# CORS Allowed Origins (comma-separated)
# Default: * (unrestricted)
# Production: Restrict to your specific domains
# Examples:
#   https://claude.ai,https://chat.openai.com
#   https://*.example.com
# LEAVE UNSET for development (uses default *)
# MCP_ALLOWED_ORIGINS=https://claude.ai

# Image Host Allowlist (comma-separated)
# Restrict which domains product images can be fetched from
# Default: (empty - allows any HTTPS domain)
# Examples:
#   cdn.example.com,images.example.com
#   *.cdn.internal.example.com
# MCP_ALLOWED_IMAGE_HOSTS=cdn.example.com,images.example.com

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================

# Rate Limit Window (milliseconds)
# Time window for rate limit calculation
# Default: 60000 (1 minute)
# MCP_RATE_LIMIT_WINDOW_MS=60000

# Rate Limit Requests Per Window
# Maximum requests allowed per window per token/IP
# Default: 60
# MCP_RATE_LIMIT_REQUESTS=60

# ============================================================================
# IMAGE FETCH CONFIGURATION
# ============================================================================

# Maximum Image Size (bytes)
# Prevents downloading excessively large image files
# Default: 5242880 (5 MB)
# MCP_MAX_IMAGE_BYTES=5242880

# Image Fetch Timeout (milliseconds)
# Maximum time to wait for image download
# Default: 10000 (10 seconds)
# MCP_FETCH_TIMEOUT_MS=10000

# ============================================================================
# LOCAL DEVELOPMENT ONLY
# ============================================================================

# MCP Transport Mode
# Options: stdio | http
# stdio: For testing with MCP Inspector locally
# http: For Cloudflare Workers
# Default: http (for Workers), auto-detected for local
# MCP_TRANSPORT=stdio
